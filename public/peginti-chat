#!/data/data/com.termux/files/usr/bin/bash

cyan='\033[0;36m'
yellow='\033[1;33m'
green='\033[0;32m'
reset='\033[0m'

clear
echo -e "${cyan}🧠 PEGINTI CHAT — Mode naturel${reset}"
echo "===================================="
echo -e "${yellow}Modules: CORE + STRAT + BIP + BO'OIVINI${reset}"
echo ""

while true; do
  read -p "💭 Vous: " question

  [[ "$question" =~ ^(quit|exit|bye|stop)$ ]] && exit 0
  [[ -z "$question" ]] && continue

  response=$(curl -s -X POST http://127.0.0.1:4000/peginti/analyse \
    -H "Content-Type: application/json" \
    -d "{\"question\":\"$question\"}")

  echo -e "${green}$response${reset}"
  echo ""
done
